POSTGRES_DB=your_database_name
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional in production (Railway): when set, this takes precedence over POSTGRES_* values.
DATABASE_URL=postgresql+psycopg://user:password@host:5432/database

# Frontend URL used as the default CORS origin when CORS_ALLOWED_ORIGINS is not set.
FRONTEND_URL=http://localhost:3000

# Optional override for multiple origins, comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

JWT_SECRET_KEY=replace_with_dev_only_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Application server port (used by containers/platform runtime).
PORT=8000
